@code {

}
@page "/dynamics/dashboard"
@using BlazorApp.Models
@using BlazorApp.Services.Implementations
@using BlazorApp.Services.Interfaces
@inject IFormSubmissionService SubmissionService
@inject IFileStorageService FileStorageService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@attribute [StreamRendering]

<PageTitle>Dynamics - Candidates</PageTitle>

<div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4">
        <div class="form-header mb-4">
            <h2 class="text-2xl font-bold theme-header">Candidates</h2>
        </div>

        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-6 py-4 rounded-2xl mb-6 flex items-center gap-3">
                @Message
            </div>
        }

        <div class="mt-2 mb-4 flex items-center justify-between">
            <div>
                <input @bind="SearchQuery" @bind:event="oninput" placeholder="Quick search" class="px-3 py-2 border rounded-lg" />
                <button class="ml-2 px-3 py-2 bg-blue-600 text-white rounded-lg" @onclick="DoSearch">Search</button>
            </div>
            <div>
                <a href="/dynamics/form" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl font-semibold shadow transition-all flex items-center gap-2">
                    <span class="text-xl">+</span> Add Candidate
                </a>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-100">
                    <tr>
                        <th class="px-4 py-3 text-left font-medium text-gray-600">Profile</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-600">Full Name</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-600 hidden md:table-cell">Email</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-600 hidden lg:table-cell">Experience</th>
                        <th class="px-4 py-3 text-right font-medium text-gray-600">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    @if (IsLoading)
                    {
                        <tr><td colspan="5" class="text-center py-8 text-gray-400"><p><em>Loading...</em></p></td></tr>
                    }
                    else
                    {
                        @foreach (var sub in Submissions)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-3">
                                    @if (sub.FileData.ContainsKey("profilePic"))
                                    {
                                        <img src="@FileStorageService.GetBlobUrl(sub.FileData["profilePic"], "profilePic/thumbnail")" class="w-12 h-12 rounded-2xl object-cover ring-2 ring-gray-200" />
                                    }
                                    else
                                    {

                                        <span class="text-gray-400">—</span>
                                    }
                                </td>
                                <td class="px-4 py-3 font-medium">@(sub.TextData.GetValueOrDefault("fullName") ?? "")</td>
                                <td class="px-4 py-3 text-gray-600 hidden md:table-cell">@(sub.TextData.GetValueOrDefault("emailAddress") ?? "")</td>
                                <td class="px-4 py-3 text-gray-600 hidden lg:table-cell">@(sub.TextData.GetValueOrDefault("experience") ?? "") years</td>
                                <td class="px-4 py-3 text-right">
                                    <a href="/dynamics/form/@sub.Id" class="text-blue-600 hover:text-blue-700 font-medium mr-6">Edit</a>
                                    <a href="/dynamics/details/@sub.Id" class="text-emerald-600 hover:text-emerald-700 font-medium mr-6">View</a>
                                    <button @onclick="() => ShowDeleteConfirm(sub.Id)"
                                    class="text-red-600 hover:text-red-700 font-medium">Delete</button>
                                </td>
                            </tr>
                        }
                        @if (!Submissions.Any())
                        {
                            <tr><td colspan="5" class="text-center py-8 text-gray-400">No records yet</td></tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 flex items-center justify-between">
            <div>
                @if (!string.IsNullOrEmpty(ContinuationToken))
                {
                    <button class="px-4 py-2 bg-gray-100 rounded-lg" @onclick="LoadMore">Load more</button>
                }
            </div>
        </div>

        @if (ShowDeleteModal)
        {
            <div class="fixed inset-0 flex items-center justify-center modal-backdrop">
                <div class="bg-white rounded-lg p-6 max-w-sm w-full">
                    <h3 class="text-lg font-semibold">Confirm delete</h3>
                    <p class="mt-3 text-sm text-gray-600">Are you sure you want to delete this record? This action cannot be undone.</p>
                    <div class="mt-4 flex justify-end gap-3">
                        <button class="px-4 py-2 rounded-lg bg-gray-100" @onclick="() => ShowDeleteModal = false">Cancel</button>
                        <button class="px-4 py-2 rounded-lg bg-red-600 text-white" @onclick="ConfirmDeleteAsync">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<FormSubmission> Submissions = new();
    private string? Message;

    // Pagination / search
    private string SearchQuery = string.Empty;
    private string? ContinuationToken;
    private const int PageSize = 5;
    private bool IsLoading = false;

    // Delete modal
    private bool ShowDeleteModal = false;
    private string? DeleteIdToConfirm;

    protected override async Task OnInitializedAsync()
    {
        // Don't await here - let the page render the loading state first
        // Fire-and-forget the data load for non-critical initial data
        _ = LoadPageAsync(null);
    }

    private async Task LoadPageAsync(string? continuation)
    {
        IsLoading = true;
        var page = await SubmissionService.GetPagedAsync(string.IsNullOrWhiteSpace(SearchQuery) ? null : SearchQuery, PageSize, continuation);
        if (continuation == null)
        {
            Submissions = page.Items;
        }
        else
        {
            Submissions.AddRange(page.Items);
        }
        ContinuationToken = page.ContinuationToken;
        IsLoading = false;
        StateHasChanged();
    }

    private async Task DoSearch()
    {
        // reset and load first page with search
        ContinuationToken = null;
        await LoadPageAsync(null);
    }

    private async Task LoadMore()
    {
        if (!string.IsNullOrEmpty(ContinuationToken))
        {
            await LoadPageAsync(ContinuationToken);
        }
    }

    private void ShowDeleteConfirm(string id)
    {
        DeleteIdToConfirm = id;
        ShowDeleteModal = true;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (string.IsNullOrEmpty(DeleteIdToConfirm)) return;
        await SubmissionService.DeleteAsync(DeleteIdToConfirm);
        ShowDeleteModal = false;
        Message = "Record deleted successfully";
        await DoSearch();
    }
}